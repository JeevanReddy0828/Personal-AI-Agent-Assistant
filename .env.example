# Optional SMTP support. Without these values, email commands create drafts only.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=you@example.com

# Optional IMAP inbox search support.
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USERNAME=you@example.com
IMAP_PASSWORD=change-me
IMAP_MAILBOX=INBOX

# Optional OAuth app configuration for Gmail/Outlook authorization URLs.
GOOGLE_CLIENT_ID=
GOOGLE_REDIRECT_URI=http://localhost:8765/oauth/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT=common
MICROSOFT_REDIRECT_URI=http://localhost:8765/oauth/callback

# Optional LLM planner. Leave unset for offline heuristic routing.
LAPTOP_AGENT_LLM_PROVIDER=heuristic
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional default browser profile path for future Playwright persistent contexts.
BROWSER_USER_DATA_DIR=
