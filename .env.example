# Optional SMTP support. Without these values, email commands create drafts only.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=you@example.com

# Optional IMAP inbox search support.
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USERNAME=you@example.com
IMAP_PASSWORD=change-me
IMAP_MAILBOX=INBOX

# Optional OAuth app configuration for Gmail/Outlook authorization URLs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8765/oauth/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
MICROSOFT_REDIRECT_URI=http://localhost:8765/oauth/callback

# Optional LLM planner. Leave provider as heuristic for offline routing.
# Set provider to "openai" and fill the keys below to use any OpenAI-compatible
# chat-completions API as the conversational brain. Examples:
#   OpenAI:  OPENAI_BASE_URL=https://api.openai.com/v1            OPENAI_MODEL=gpt-4o-mini
#   NVIDIA:  OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1  OPENAI_MODEL=meta/llama-3.1-8b-instruct
#   (prefer a small fast model — routing is reliable via few-shot, and a big model is not needed)
# Copy this file to .env (gitignored) and put your real key there.
LAPTOP_AGENT_LLM_PROVIDER=heuristic
OPENAI_API_KEY=
OPENAI_MODEL=
# Optional stronger models, picked automatically by task complexity.
OPENAI_SMART_MODEL=
# The ultra tier handles the hardest questions. If it's an NVIDIA reasoning model
# (e.g. nvidia/nemotron-3-ultra-550b-a55b) it thinks before answering — chain-of-thought
# is requested with the budget below and kept internal; only the final answer is shown.
OPENAI_ULTRA_MODEL=
# Chain-of-thought token budget for the reasoning (ultra) tier.
OPENAI_REASONING_BUDGET=16384
# Optional vision model for "look at my screen" and "describe image".
OPENAI_VISION_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional cross-provider fallback (OpenRouter). When every primary tier above is
# congested/unreachable, chat falls over to OpenRouter's free models so it keeps
# answering. Just set the key — the model defaults to a free one (override if you like).
#   Get a free key at https://openrouter.ai/keys
# Tip: free models can be rate-limited individually; if one 429s, pick another free
# id from https://openrouter.ai/models?max_price=0  (or use openrouter/free to auto-route).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional real web-search API for reliable results (web search, news grounding,
# research). No key => DuckDuckGo. Provider is inferred from whichever key is set.
#   Brave:    https://api.search.brave.com/
#   Serper:   https://serper.dev/        (Google results)
#   SerpApi:  https://serpapi.com/       (Google results — a DIFFERENT service from Serper)
SEARCH_PROVIDER=
SEARCH_API_KEY=
# Or set a provider-specific key instead of SEARCH_API_KEY:
BRAVE_API_KEY=
SERPER_API_KEY=
SERPAPI_API_KEY=

# Optional Obsidian vault folder used as durable, human-readable memory.
OBSIDIAN_VAULT=

# Optional default browser profile path for future Playwright persistent contexts.
BROWSER_USER_DATA_DIR=

# Optional web-app bind address. Defaults to loopback (127.0.0.1) — the app has no
# auth, so only change the host if you understand the exposure (e.g. 0.0.0.0 on a
# trusted LAN behind your own auth). The port defaults to 8770.
LAPTOP_AGENT_HOST=127.0.0.1
LAPTOP_AGENT_PORT=8770
