# Optional SMTP support. Without these values, email commands create drafts only.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=you@example.com

# Optional IMAP inbox search support.
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USERNAME=you@example.com
IMAP_PASSWORD=change-me
IMAP_MAILBOX=INBOX

# Optional OAuth app configuration for Gmail/Outlook authorization URLs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8765/oauth/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
MICROSOFT_REDIRECT_URI=http://localhost:8765/oauth/callback

# Optional LLM planner. Leave provider as heuristic for offline routing.
# Set provider to "openai" and fill the keys below to use any OpenAI-compatible
# chat-completions API as the conversational brain. Examples:
#   OpenAI:  OPENAI_BASE_URL=https://api.openai.com/v1            OPENAI_MODEL=gpt-4o-mini
#   NVIDIA:  OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1  OPENAI_MODEL=meta/llama-3.1-8b-instruct
#   (prefer a small fast model — routing is reliable via few-shot, and a big model is not needed)
# Copy this file to .env (gitignored) and put your real key there.
LAPTOP_AGENT_LLM_PROVIDER=heuristic
OPENAI_API_KEY=
OPENAI_MODEL=
# Optional stronger models, picked automatically by task complexity.
OPENAI_SMART_MODEL=
OPENAI_ULTRA_MODEL=
# Optional vision model for "look at my screen" and "describe image".
OPENAI_VISION_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional Obsidian vault folder used as durable, human-readable memory.
OBSIDIAN_VAULT=

# Optional default browser profile path for future Playwright persistent contexts.
BROWSER_USER_DATA_DIR=
